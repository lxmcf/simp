let x = 400
let y = 300

function reset_player () {
    x = 400
    y = 300
}

while true {
    if is_key_down ("SPACE") {
        reset_player ()
    }

    -- Cast bool to int and use as axis for movement
    let xaxis = is_key_down ("RIGHT")::int - is_key_down ("LEFT")::int
    let yaxis = is_key_down ("DOWN")::int - is_key_down ("UP")::int

    x += xaxis * PLAYER_SPEED
    y += yaxis * PLAYER_SPEED

    draw_circle (x, y, 50)

    -- Halt execution for 1 step/frame
    sleep 0
}
