CC = odin
CONFIG = DEBUG

CFLAGS = -vet -min-link-libs -strict-style -disallow-do
OPT = none

!IF "$(CONFIG)" == "DEBUG"
CFLAGS = $(CFLAGS) -debug -microarch:native
!ELSEIF "$(CONFIG)" == "RELEASE"
OPT = speed
!ENDIF

all: build

build:
    @if not exist build mkdir build
    $(CC) build cli/ -out:build/simp.exe $(CFLAGS) -o:$(OPT)

run: build
    build\simp.exe

test:
    $(CC) test tests

clean:
    @if exist build rmdir /s /q build
